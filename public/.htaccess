Options -MultiViews
RewriteEngine On
RewriteBase /

# API requests must reach api/index.php — never the Vue SPA
RewriteCond %{REQUEST_URI} ^/api(/|$)
RewriteRule ^ - [L]

# Cache: always revalidate shell; hashed assets are immutable
<IfModule mod_headers.c>
  <FilesMatch "^index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
  <FilesMatch "\.(js|mjs|css|woff2?)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

# If the request is for an existing file or directory, serve it directly
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Otherwise send everything to index.html (Vue Router handles it)
RewriteRule ^ index.html [L,E=spa_html:1]

<IfModule mod_headers.c>
  Header set Cache-Control "no-cache, no-store, must-revalidate" env=spa_html
  Header set Pragma "no-cache" env=spa_html
  Header set Expires "0" env=spa_html
</IfModule>
